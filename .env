# Axios base URL — relative path so the browser sees same-origin requests.
# The Vite dev server (vite.config.ts) intercepts /api and forwards to
# API_PROXY_TARGET below. No CORS, no ngrok browser-warning interstitial.
VITE_API_BASE_URL=/api

# Upstream the Vite dev proxy forwards /api/* to.
# Swap between localhost and an ngrok tunnel without touching axios code.
# Examples:
#   API_PROXY_TARGET=http://localhost:3001
#   API_PROXY_TARGET=https://bloating-plausibly-ardently.ngrok-free.dev
API_PROXY_TARGET=https://bloating-plausibly-ardently.ngrok-free.dev
