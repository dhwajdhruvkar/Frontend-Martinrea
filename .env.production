# Production build config (used by `vite build`).
# Calls go to the same-origin /api path, which Vercel rewrites (see vercel.json)
# to the backend — this avoids browser CORS with the ngrok-free tunnel.
VITE_API_BASE_URL=/api

# AI Invoice OCR service — same-origin /ocr-api path, rewritten by Vercel
# (see vercel.json) to the OCR backend to avoid browser CORS.
VITE_OCR_API_BASE_URL=/ocr-api
